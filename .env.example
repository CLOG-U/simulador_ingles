# PostgreSQL
POSTGRES_USER=simulador
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=simulador_ingles
DATABASE_URL=postgresql+asyncpg://simulador:change_me_in_production@db:5432/simulador_ingles

# Backend
SECRET_KEY=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend (Vite) — desarrollo local
# En Render (Dockerfile raíz) el frontend se embeben con VITE_API_BASE_URL=/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Producción (Render + Supabase) ---
# Ver .env.production.example y docs/deploy-render.md
# DATABASE_URL=postgresql+asyncpg://postgres:...@db.xxx.supabase.co:5432/postgres
# ENVIRONMENT=production
# SECRET_KEY=...
# CORS_ORIGINS=https://simulador.onrender.com
# VITE_API_BASE_URL=https://simulador-api.onrender.com/api/v1
