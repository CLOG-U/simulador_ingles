# Plantilla para producción (Render + Supabase)
# NO subas valores reales a GitHub.

# --- Supabase (Session pooler) ---
DATABASE_URL=postgresql+asyncpg://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-TU_REGION.pooler.supabase.com:5432/postgres

# --- Backend Web Service (simulador-api) ---
# Root Directory = backend
ENVIRONMENT=production
SECRET_KEY=genera_un_string_largo_aleatorio_minimo_32_caracteres
# URL exacta del Static Site, SIN barra final
CORS_ORIGINS=https://TU-FRONTEND.onrender.com
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO

# --- Frontend Static Site (simulador) ---
# Variable de BUILD
VITE_API_BASE_URL=https://simulador-api-8jwy.onrender.com/api/v1
