# Plantilla para producción (Render + Supabase)
# Copia a .env.production local o pega estas variables en el panel de Render.
# NO subas valores reales a GitHub.

# --- Supabase (solo PostgreSQL) ---
# IMPORTANTE en Render: usa Session pooler, NO la conexión directa db.xxx.supabase.co
# (la directa falla con "Network is unreachable" por IPv6)
#
# Supabase → Settings → Database → Connection string → Session pooler → URI
# Cambia el prefijo a postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-TU_REGION.pooler.supabase.com:5432/postgres

# --- App unificada en Render (Web Service: simulador-api) ---
# Root Directory vacío + Dockerfile Path ./Dockerfile
ENVIRONMENT=production
SECRET_KEY=genera_un_string_largo_aleatorio_minimo_32_caracteres
# Misma URL del Web Service (sin barra final)
CORS_ORIGINS=https://simulador-api.onrender.com
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO
